    "reasoning_rules": [
      {
        "id": "same_venue_series",
        "description": "같은 장소에서 같은 주최가 반복적으로 여는 이벤트는 시리즈로 추정",
        "pattern": "(?e1 hostsAt ?v) AND (?e2 hostsAt ?v) AND (?e1 organizedBy ?o) AND (?e2 organizedBy ?o) => (?e1 partOfSeries ?e2)"
      },
      {
        "id": "same_dong_combo",
        "description": "같은 동에서 같은 날 열리는 이벤트는 묶어 방문 후보",
        "pattern": "(?e1 hostsAt ?v1) AND (?e2 hostsAt ?v2) AND (?v1 locatedIn ?d) AND (?v2 locatedIn ?d) AND (?e1 sameDate ?e2) => (?e1 visitCombo ?e2)"
      },
      {
        "id": "age_group_overlap",
        "description": "같은 연령대 대상 이벤트는 잠재적 방문 후보군",
        "pattern": "(?e1 targetsAgeGroup ?a) AND (?e2 targetsAgeGroup ?a) => (?e1 candidateFor ?a)"
      },
      {
        "id": "operator_kid_friendliness",
        "description": "어린이 도서관·과학관·평생학습관이 운영하는 이벤트는 기본적으로 어린이 친화도 가산점",
        "pattern": "(?o operates ?v) AND (?o orgType in {도서관,과학관,평생학습관,박물관,가족센터}) AND (?e hostsAt ?v) => (?e kidFriendlyBoost +0.2)"
      },
      {
        "id": "indoor_rainy_fallback",
        "description": "동일 동 내 실내 이벤트는 우천 시 야외 이벤트의 대체 후보",
        "pattern": "(?e1 indoor_outdoor outdoor) AND (?e2 indoor_outdoor indoor) AND (?e1 sameDong ?e2) => (?e2 rainyFallbackFor ?e1)"
      }
    ],
    "max_new_classes_per_day": 3,
