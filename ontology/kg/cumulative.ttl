@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct: <http://purl.org/dc/terms/> .

# Onto-OSINT-Yuseong-Event — cumulative KG (유효 엔티티만)
# validity_today: 2026-06-10 — 종료된 Event 인스턴스/관련 트리플 제외
<#cumulative> a prov:Entity ;
  dct:date "2026-06-10"^^xsd:date ;
  dct:modified "2026-06-09"^^xsd:date .

# === Schema: classes ===
yseo:Entity a owl:Class ;
  rdfs:label "엔티티"@ko ;
  rdfs:comment "최상위 클래스"@ko .
yseo:Event a owl:Class ;
  rdfs:label "이벤트"@ko ;
  rdfs:comment "유성구 일대에서 개최되는 행사·체험·공연·교육 프로그램"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:Venue a owl:Class ;
  rdfs:label "장소"@ko ;
  rdfs:comment "이벤트가 열리는 물리적 장소 (도서관·과학관·공원·문화원 등)"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:Organization a owl:Class ;
  rdfs:label "주최기관"@ko ;
  rdfs:comment "이벤트를 주최·주관·후원하는 기관"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:Shop a owl:Class ;
  rdfs:label "가게"@ko ;
  rdfs:comment "용성로20 인근 민간 상업 시설 — 카페·식당·키즈카페·공방·학원 등"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:Activity a owl:Class ;
  rdfs:label "활동"@ko ;
  rdfs:comment "이벤트의 핵심 활동 유형 (체험·전시·공연·강연·축제·스포츠 등)"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:AgeGroup a owl:Class ;
  rdfs:label "대상연령"@ko ;
  rdfs:comment "이벤트가 적합한 연령대 분류"@ko ;
  rdfs:subClassOf yseo:Entity .
yseo:Dong a owl:Class ;
  rdfs:label "행정동"@ko ;
  rdfs:comment "유성구 행정동 단위 — 동별 모니터링 대상"@ko ;
  rdfs:subClassOf yseo:Entity .

# === Schema: relations ===
yser:hostsAt a owl:ObjectProperty ;
  rdfs:label "개최장소"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Venue .
yser:organizedBy a owl:ObjectProperty ;
  rdfs:label "주최"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Organization .
yser:locatedIn a owl:ObjectProperty ;
  rdfs:label "소재동"@ko ;
  rdfs:domain yseo:Venue ;
  rdfs:range yseo:Dong .
yser:featuresActivity a owl:ObjectProperty ;
  rdfs:label "활동내용"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Activity .
yser:targetsAgeGroup a owl:ObjectProperty ;
  rdfs:label "대상연령"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:AgeGroup .
yser:followsEvent a owl:ObjectProperty ;
  rdfs:label "후속회차"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Event .
yser:partOfSeries a owl:ObjectProperty ;
  rdfs:label "시리즈일부"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Event .
yser:nearby a owl:ObjectProperty ;
  rdfs:label "근처"@ko ;
  rdfs:domain yseo:Venue ;
  rdfs:range yseo:Venue .
yser:operates a owl:ObjectProperty ;
  rdfs:label "운영"@ko ;
  rdfs:domain yseo:Organization ;
  rdfs:range yseo:Venue .
yser:supersedes a owl:ObjectProperty ;
  rdfs:label "대체"@ko ;
  rdfs:domain yseo:Event ;
  rdfs:range yseo:Event .
yser:shopHosts a owl:ObjectProperty ;
  rdfs:label "가게주최"@ko ;
  rdfs:domain yseo:Shop ;
  rdfs:range yseo:Event .
yser:shopLocatedIn a owl:ObjectProperty ;
  rdfs:label "가게소재동"@ko ;
  rdfs:domain yseo:Shop ;
  rdfs:range yseo:Dong .
yser:withinRing a owl:ObjectProperty ;
  rdfs:label "동심원소속"@ko ;
  rdfs:domain yseo:Venue ;
  rdfs:range yseo:GeoRing .
yser:shopWithinRing a owl:ObjectProperty ;
  rdfs:label "가게동심원"@ko ;
  rdfs:domain yseo:Shop ;
  rdfs:range yseo:GeoRing .

